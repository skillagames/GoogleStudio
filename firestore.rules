rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid is string &&
               data.email is string &&
               data.role in ['user', 'admin'] &&
               data.createdAt is timestamp &&
               (data.get('displayName', '') is string) &&
               (data.get('showInsights', true) is bool);
      }

      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    request.resource.data.role == 'user' &&
                    isValidUser(request.resource.data);
      allow update: if (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role)) &&
                    isValidUser(request.resource.data) &&
                    request.resource.data.uid == resource.data.uid &&
                    request.resource.data.createdAt == resource.data.createdAt;
    }

    // --- Devices ---
    match /devices/{deviceId} {
      function isValidDevice(data) {
        return data.serialNumber is string && data.serialNumber.size() <= 64 &&
               data.imei is string && data.imei.size() <= 32 &&
               data.iccid is string && data.iccid.size() <= 32 &&
               data.name is string && data.name.size() <= 100 &&
               data.ownerId is string &&
               data.subscriptionStatus in ['active', 'expired', 'inactive'] &&
               (data.subscriptionStatus == 'inactive' ? true : data.expirationDate is timestamp) &&
               (data.get('autoRenew', false) is bool);
      }

      allow read: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidDevice(request.resource.data) && 
                    (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin()) &&
                    isValidDevice(request.resource.data) &&
                    request.resource.data.ownerId == resource.data.ownerId; // Owner cannot be changed by user
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // --- Usage Stats ---
    match /devices/{deviceId}/usage/{statId} {
      function isValidUsage(data) {
        return (data.timestamp is timestamp || data.timestamp is string) &&
               data.dataUsedMb is number && data.dataUsedMb >= 0 &&
               data.activeHours is number && data.activeHours >= 0;
      }

      allow read: if isSignedIn() && (get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerId == request.auth.uid || isAdmin()) &&
                    isValidUsage(request.resource.data);
      allow delete: if isSignedIn() && (get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerId == request.auth.uid || isAdmin());
    }

    // --- Master Registry ---
    match /master_registry/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn(); // Allow seeding and updates for demo purposes
    }

    // --- Plans ---
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
